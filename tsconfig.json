{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": false,
    "noCheck": true,
    "noEmit": true,
    "allowJs": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": [
    "packages/**/*.ts",
    "src/**/*.ts",
    "tests/**/*.ts",
    "examples/**/*.ts",
    "starter/hooks/**/*.ts"
  ]
}
